---
import Modal from "../components/Modal.astro";
import MenuIcon from "../assets/icons/menu.svg";
import CloseIcon from "../assets/icons/close.svg";
import HelpIcon from "../assets/icons/help.svg";
import MoonIcon from "../assets/icons/moon.svg";
import SunIcon from "../assets/icons/sun.svg";
import MailIcon from "../assets/icons/mail.svg";
import CheckIcon from "../assets/icons/check.svg";
import GithubIcon from "../assets/icons/github.svg";
import ExternalLinkIcon from "../assets/icons/external-link.svg";

const email = "mate.gasme@gmail.com";
const github = "mateogasme/calculadorainflacion";
---

<header
    class="sticky top-0 z-50 w-full bg-secondary md:bg-secondary/60 md:backdrop-blur-md border-b border-primary/[0.04] transition-colors duration-300"
>
    <div
        class="flex items-center justify-between w-full h-16 max-w-[640px] px-6 md:px-0 mx-auto"
    >
        <button
            id="mobile-menu-toggle"
            aria-controls="main-nav"
            aria-expanded="false"
            aria-label="Abrir menú de navegación"
            class="md:hidden flex items-center justify-center w-8 h-8 rounded-lg text-primary/60 hover:text-primary hover:bg-primary/5 transition-all outline-none"
        >
            <MenuIcon id="menu-icon" class="block" />
            <CloseIcon id="close-icon" class="hidden" />
        </button>

        <!-- Navegación -->
        <nav
            id="main-nav"
            aria-label="Principal"
            class="flex opacity-0 pointer-events-none -translate-y-2 md:translate-y-0 md:opacity-100 md:pointer-events-auto transition-all duration-300 md:transition-none flex-1 absolute md:static top-full left-0 w-full md:w-auto bg-secondary border-b border-primary/[0.04] md:bg-transparent md:border-none md:backdrop-blur-none px-6 py-5 md:p-0 shadow-2xl shadow-black/10 md:shadow-none z-40"
        >
            <ul
                class="flex flex-col md:flex-row items-start md:items-center gap-5 md:gap-5 text-base md:text-sm font-medium"
            >
                <li>
                    <a
                        href="/"
                        class="text-primary/60 hover:text-primary transition-colors block py-2 md:inline-block md:py-1 outline-none focus-visible:ring-2 focus-visible:ring-blue focus-visible:ring-offset-2 focus-visible:ring-offset-secondary rounded-sm"
                    >
                        Calculadora
                    </a>
                </li>
                <li>
                    <a
                        href="/salario"
                        class="text-primary/60 hover:text-primary transition-colors block py-2 md:inline-block md:py-1 outline-none focus-visible:ring-2 focus-visible:ring-blue focus-visible:ring-offset-2 focus-visible:ring-offset-secondary rounded-sm"
                    >
                        Aumento salario
                    </a>
                </li>
                <li>
                    <a
                        href="/metodologia"
                        class="text-primary/60 hover:text-primary transition-colors block py-2 md:inline-block md:py-1 outline-none focus-visible:ring-2 focus-visible:ring-blue focus-visible:ring-offset-2 focus-visible:ring-offset-secondary rounded-sm"
                    >
                        Metodología
                    </a>
                </li>
                <li>
                    <button
                        data-open-modal="contact-modal"
                        aria-label="Abrir información de contacto"
                        class="text-primary/60 hover:text-primary transition-colors block py-2 md:inline-block md:py-1 outline-none focus-visible:ring-2 focus-visible:ring-blue focus-visible:ring-offset-2 focus-visible:ring-offset-secondary rounded-sm cursor-pointer"
                    >
                        Contacto
                    </button>
                </li>
            </ul>
        </nav>

        <div class="flex items-center gap-2">
            <div class="relative group/github">
                <a
                    href="https://github.com/mateogasme/calculadorainflacion"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="GitHub del proyecto"
                    class="flex items-center justify-center w-8 h-8 rounded-lg text-primary/60 hover:text-primary hover:bg-primary/5 transition-all outline-none cursor-auto"
                >
                    <GithubIcon />
                </a>

                <!-- Tooltip -->
                <span
                    class="absolute top-full left-1/2 -translate-x-1/2 mt-2 opacity-0 group-hover/github:opacity-100 transition-opacity duration-200 pointer-events-none flex items-center gap-1.5 bg-primary text-secondary text-[11px] font-medium rounded-md shadow-lg z-10 px-2.5 py-1.5 min-w-max"
                >
                    <ExternalLinkIcon class="w-3.5 h-3.5 opacity-70" />
                    Abrir enlace
                    <span
                        class="absolute bottom-full left-1/2 -translate-x-1/2 border-[4px] border-transparent border-b-primary"
                    ></span>
                </span>
            </div>

            <!-- Botón de Tema a la derecha -->
            <button
                id="theme-toggle"
                aria-label="Alternar modo oscuro"
                class="flex items-center justify-center w-8 h-8 rounded-lg text-primary/60 hover:text-primary hover:bg-primary/5 transition-all outline-none"
            >
                <MoonIcon id="moon-icon" class="block" />
                <SunIcon id="sun-icon" class="hidden" />
            </button>
        </div>
    </div>

    <Modal id="contact-modal" title="Datos e información">
        <p class="text-[15px] leading-relaxed">
            Si querés hacernos alguna sugerencia, reportar un error o
            simplemente ponerte en contacto, podés hacerlo a través de los
            siguientes medios:
        </p>
        <div class="flex flex-col gap-2 mt-1">
            <button
                id="copy-email-btn"
                data-email={email}
                class="relative group/copy flex items-center gap-3 text-sm font-medium hover:text-blue transition-none w-fit p-2 -ml-2 rounded-lg cursor-pointer outline-none"
            >
                <MailIcon
                    class="text-primary/60 group-hover/copy:text-blue transition-none"
                />
                <span class="group-hover/copy:underline">{email}</span>

                <!-- Tooltip -->
                <span
                    class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 opacity-0 group-hover/copy:opacity-100 transition-opacity duration-200 pointer-events-none flex items-center justify-center bg-primary text-secondary text-[11px] font-medium rounded-md shadow-lg z-10 px-2.5 py-1 min-w-[65px]"
                >
                    <span id="tooltip-copy-text" class="flex items-center">
                        Copiar
                    </span>
                    <span
                        id="tooltip-copied-text"
                        class="hidden items-center gap-1 text-green-500 font-semibold"
                    >
                        <CheckIcon />
                        ¡Copiado!
                    </span>
                    <span
                        class="absolute top-full left-1/2 -translate-x-1/2 border-[4px] border-transparent border-t-primary"
                    ></span>
                </span>
            </button>
            <a
                href={`https://github.com/${github}`}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-3 text-sm font-medium hover:text-blue hover:underline transition-none w-fit p-2 -ml-2 rounded-lg"
            >
                <GithubIcon
                    class="text-primary/60 group-hover:text-blue transition-none"
                />
                {github}
            </a>
        </div>
    </Modal>
</header>

<script>
    document.addEventListener("astro:page-load", () => {
        const themeToggle = document.getElementById("theme-toggle");
        const moonIcon = document.getElementById("moon-icon");
        const sunIcon = document.getElementById("sun-icon");

        const updateIcons = (isDark: boolean) => {
            if (!moonIcon || !sunIcon) return;
            if (isDark) {
                moonIcon.classList.add("hidden");
                moonIcon.classList.remove("block");
                sunIcon.classList.add("block");
                sunIcon.classList.remove("hidden");
            } else {
                moonIcon.classList.add("block");
                moonIcon.classList.remove("hidden");
                sunIcon.classList.add("hidden");
                sunIcon.classList.remove("block");
            }
        };

        const handleToggleClick = () => {
            const element = document.documentElement;
            element.classList.toggle("dark");
            const isDark = element.classList.contains("dark");
            localStorage.setItem("theme", isDark ? "dark" : "light");
            updateIcons(isDark);
        };

        themeToggle?.addEventListener("click", handleToggleClick);

        // Revisar el tema activo al cargar la página (Layout.astro script)
        if (document.documentElement.classList.contains("dark")) {
            updateIcons(true);
        }

        // Lógica del menú móvil
        const mobileMenuToggle = document.getElementById("mobile-menu-toggle");
        const mainNav = document.getElementById("main-nav");
        const menuIconToggle = document.getElementById("menu-icon");
        const closeIconToggle = document.getElementById("close-icon");

        mobileMenuToggle?.addEventListener("click", () => {
            const isExpanded =
                mobileMenuToggle.getAttribute("aria-expanded") === "true";
            mobileMenuToggle.setAttribute("aria-expanded", String(!isExpanded));

            if (isExpanded) {
                // Cerrar menú
                mainNav?.classList.add(
                    "opacity-0",
                    "pointer-events-none",
                    "-translate-y-2",
                );
                mainNav?.classList.remove(
                    "opacity-100",
                    "pointer-events-auto",
                    "translate-y-0",
                );
                menuIconToggle?.classList.remove("hidden");
                menuIconToggle?.classList.add("block");
                closeIconToggle?.classList.add("hidden");
                closeIconToggle?.classList.remove("block");
                mobileMenuToggle.setAttribute(
                    "aria-label",
                    "Abrir menú de navegación",
                );
            } else {
                // Abrir menú
                mainNav?.classList.remove(
                    "opacity-0",
                    "pointer-events-none",
                    "-translate-y-2",
                );
                mainNav?.classList.add(
                    "opacity-100",
                    "pointer-events-auto",
                    "translate-y-0",
                );
                menuIconToggle?.classList.add("hidden");
                menuIconToggle?.classList.remove("block");
                closeIconToggle?.classList.remove("hidden");
                closeIconToggle?.classList.add("block");
                mobileMenuToggle.setAttribute(
                    "aria-label",
                    "Cerrar menú de navegación",
                );
            }
        });

        // Cerrar el menú al cambiar el tamaño de la ventana (para evitar bugs de resize)
        window.addEventListener("resize", () => {
            if (window.innerWidth >= 768) {
                mainNav?.classList.add(
                    "opacity-0",
                    "pointer-events-none",
                    "-translate-y-2",
                );
                mainNav?.classList.remove(
                    "opacity-100",
                    "pointer-events-auto",
                    "translate-y-0",
                );
                menuIconToggle?.classList.remove("hidden");
                menuIconToggle?.classList.add("block");
                closeIconToggle?.classList.add("hidden");
                closeIconToggle?.classList.remove("block");
                mobileMenuToggle?.setAttribute("aria-expanded", "false");
                mobileMenuToggle?.setAttribute(
                    "aria-label",
                    "Abrir menú de navegación",
                );
            }
        });

        // Lógica para copiar el correo electrónico
        const copyEmailBtn = document.getElementById("copy-email-btn");
        const tooltipCopyText = document.getElementById("tooltip-copy-text");
        const tooltipCopiedText = document.getElementById(
            "tooltip-copied-text",
        );

        copyEmailBtn?.addEventListener("click", async () => {
            const emailToCopy = copyEmailBtn.getAttribute("data-email");
            if (emailToCopy) {
                try {
                    await navigator.clipboard.writeText(emailToCopy);

                    tooltipCopyText?.classList.add("hidden");
                    tooltipCopyText?.classList.remove("flex");
                    tooltipCopiedText?.classList.remove("hidden");
                    tooltipCopiedText?.classList.add("flex");

                    setTimeout(() => {
                        tooltipCopiedText?.classList.add("hidden");
                        tooltipCopiedText?.classList.remove("flex");
                        tooltipCopyText?.classList.remove("hidden");
                        tooltipCopyText?.classList.add("flex");
                    }, 2000);
                } catch (err) {
                    console.error("Error al copiar el email: ", err);
                }
            }
        });
    });
</script>
