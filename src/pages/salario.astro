---
import Layout from "../layouts/Layout.astro";
import Header from "../components/common/layout/Header.astro";
import SalarioHero from "../components/features/salary/Hero.astro";
import SalarioCalculator from "../components/features/salary/Calculator.astro";
import SalarioResult from "../components/features/salary/Result.astro";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebSite",
            "@id": "https://calculadorainflacion.vercel.app/#website",
            name: "Calculadora de Inflación",
            url: "https://calculadorainflacion.vercel.app/",
            inLanguage: "es-AR",
        },
        {
            "@type": "WebApplication",
            "@id": "https://calculadorainflacion.vercel.app/salario#webapp-salario",
            name: "Calculadora de Aumento Salarial vs Inflación",
            applicationCategory: "FinanceApplication",
            operatingSystem: "All",
            inLanguage: "es-AR",
            description:
                "Herramienta que te permite comparar si el aumento de tu sueldo superó o perdió contra la inflación acumulada del mismo período en Argentina.",
            url: "https://calculadorainflacion.vercel.app/salario",
            isPartOf: {
                "@id": "https://calculadorainflacion.vercel.app/#website",
            },
            offers: {
                "@type": "Offer",
                price: "0",
                priceCurrency: "ARS",
            },
        },
        {
            "@type": "BreadcrumbList",
            itemListElement: [
                {
                    "@type": "ListItem",
                    position: 1,
                    name: "Inicio",
                    item: "https://calculadorainflacion.vercel.app/",
                },
                {
                    "@type": "ListItem",
                    position: 2,
                    name: "Aumento salario",
                    item: "https://calculadorainflacion.vercel.app/salario",
                },
            ],
        },
    ],
});
---

<Layout
    title="Analizar Aumento Salarial vs Inflación"
    description="Calculá exactamente si tu nuevo sueldo o propuesta laboral empató, ganó o perdió poder adquisitivo contra la inflación oficial en Argentina."
    url="https://calculadorainflacion.vercel.app/salario"
    schema={schema}
>
    <Header />
    <main>
        <SalarioHero />
        <SalarioCalculator />
        <SalarioResult />
    </main>
</Layout>
