---
import Layout from "../layouts/Layout.astro";
import Header from "../sections/Header.astro";
import SalarioHero from "../sections/SalarioHero.astro";
import SalarioCalculator from "../sections/SalarioCalculator.astro";
import SalarioResult from "../sections/SalarioResult.astro";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebSite",
            "@id": "https://datosar.com/#website",
            name: "DatosAR",
            url: "https://datosar.com/",
            inLanguage: "es-AR",
        },
        {
            "@type": "WebApplication",
            "@id": "https://datosar.com/salario#webapp-salario",
            name: "Calculadora de Aumento Salarial vs Inflación",
            applicationCategory: "FinanceApplication",
            operatingSystem: "All",
            inLanguage: "es-AR",
            description:
                "Herramienta que te permite comparar si el aumento de tu sueldo superó o perdió contra la inflación acumulada del mismo período en Argentina.",
            url: "https://datosar.com/salario",
            isPartOf: { "@id": "https://datosar.com/#website" },
            offers: {
                "@type": "Offer",
                price: "0",
                priceCurrency: "ARS",
            },
        },
        {
            "@type": "BreadcrumbList",
            itemListElement: [
                {
                    "@type": "ListItem",
                    position: 1,
                    name: "Inicio",
                    item: "https://datosar.com/",
                },
                {
                    "@type": "ListItem",
                    position: 2,
                    name: "Aumento salario",
                    item: "https://datosar.com/salario",
                },
            ],
        },
    ],
});
---

<Layout
    title="Analizar Aumento Salarial vs Inflación | DatosAR"
    description="Calculá exactamente si tu nuevo sueldo o propuesta laboral empató, ganó o perdió poder adquisitivo contra la inflación oficial en Argentina."
    url="https://datosar.com/salario"
    schema={schema}
>
    <Header />
    <main>
        <SalarioHero />
        <SalarioCalculator />
        <SalarioResult />
    </main>
</Layout>
