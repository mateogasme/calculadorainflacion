---

---

<section class="w-full max-w-[640px] px-6 md:px-0 mx-auto mt-[56px] pb-24">
    <!-- Contenedor del Resultado (Oculto por defecto) -->
    <div
        id="result-container"
        class="hidden flex-col w-full animate-fade-in-up"
    >
        <div
            class="rounded-[24px] border border-primary/5 bg-primary/[0.015] shadow-sm overflow-hidden"
        >
            <!-- Cabecera de la tarjeta -->
            <div
                class="flex items-center justify-between px-6 md:px-8 py-5 border-b border-primary/5"
            >
                <div class="flex items-center gap-2.5">
                    <div class="relative flex h-2 w-2">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2 w-2 bg-blue"
                        ></span>
                    </div>
                    <span
                        class="text-sm font-semibold text-primary/90 tracking-tight"
                        >Resultado del cálculo</span
                    >
                </div>
                <!-- Período calculado -->
                <div
                    class="px-2.5 py-1 bg-primary/5 border border-primary/5 rounded-md text-[13px] font-medium text-primary/70 flex items-center gap-1.5 tabular-nums tracking-tight"
                >
                    <span id="label-origin">MM/YYYY</span>
                    <span class="text-primary/60 font-bold">→</span>
                    <span id="label-dest">MM/YYYY</span>
                </div>
            </div>

            <!-- Cuerpo principal -->
            <div class="p-6 md:p-8 flex flex-col">
                <span
                    class="text-sm font-medium text-primary/60 mb-2 tracking-tight"
                    >Monto ajustado al presente</span
                >
                <div class="flex items-baseline gap-1.5">
                    <span class="text-3xl font-medium text-primary/70">$</span>
                    <h3
                        id="result-amount"
                        class="text-5xl md:text-[64px] font-bold tracking-[-0.04em] md:tracking-[-0.06em] text-primary break-all leading-none"
                    >
                        0
                    </h3>
                </div>

                <p
                    id="result-description"
                    class="text-[15px] text-primary/60 font-medium mt-6 leading-relaxed bg-primary/5 p-4 rounded-xl border border-primary/5"
                >
                    Calculando cifras exactas...
                </p>

                <!-- Gráfico de Evolución Evolutivo con ECharts -->
                <div
                    id="chart-wrapper"
                    class="hidden mt-8 w-full h-[220px] relative"
                >
                    <div id="echarts-container" class="w-full h-full"></div>
                </div>
            </div>

            <!-- Datos adicionales estructurados -->
            <div
                class="grid grid-cols-2 border-t border-primary/5 bg-primary/[0.01] divide-x divide-primary/5"
            >
                <div class="p-6 md:p-8 flex flex-col gap-1.5 overflow-hidden">
                    <span
                        class="text-[13px] font-medium text-primary/50 tracking-tight"
                        >Inflación Acumulada</span
                    >
                    <span
                        id="result-inflation"
                        class="text-2xl md:text-[32px] font-bold tracking-tighter text-primary tabular-nums leading-none break-all"
                        >0%</span
                    >
                </div>
                <div class="p-6 md:p-8 flex flex-col gap-1.5 overflow-hidden">
                    <span
                        class="text-[13px] font-medium text-primary/50 tracking-tight"
                        >Pérdida de Valor</span
                    >
                    <span
                        id="result-loss"
                        class="text-2xl md:text-[32px] font-bold tracking-tighter text-red-500 tabular-nums leading-none break-all"
                        >-0%</span
                    >
                </div>
            </div>
        </div>
    </div>
</section>
